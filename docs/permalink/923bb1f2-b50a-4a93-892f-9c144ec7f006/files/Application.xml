<Application name="hello-xml-app" version="0.1.0">

  <Screen>
    <Panel use="main-panel" />
  </Screen>

  <State name="application" initial="hello-world">

    <State name="hello-world" title="Hello World">

      <Goal use="screen" state="hello-world" />

      <State name="hello-universe" title="Hello Universe">

        <Goal use="screen" state="hello-universe" />

      </State>

    </State>

  </State>

  <Interfaces>
    <Panel name="main-panel">
      <Chat name="main-chat" />
    </Panel>
  </Interfaces>

  <Components>
    <Component name="panel" tag="x-panel" url="src/components/panel/panel.js" />
    <Component name="chat" tag="x-chat" url="src/components/chat/chat.js" />
    <Component name="alert" tag="x-alert" url="src/components/alert/alert.js" />
    <Component name="button" tag="x-button" url="src/components/button/button.js" />
  </Components>

  <Goals>

    <Goal name="screen" default="empty">

      <Plan state="empty">
        <Action use="cls" />
      </Plan>

      <Plan state="hello-world">
        <Action use="cls" />

        <Action
          use="alert"
          text="Hello World"
          color="primary" />

        <Action
          use="goto"
          to="hello-universe"
          text="Go to Hello Universe"
          color="secondary" />
      </Plan>

      <Plan state="hello-universe">
        <Action use="cls" />

        <Action
          use="alert"
          text="Hello Universe"
          color="success" />

        <Action
          use="goto"
          to=".."
          text="Go to Hello World"
          color="secondary" />
      </Plan>

    </Goal>

  </Goals>

  <Actions>
    <Action name="cls" url="src/actions/cls/cls.js" />
    <Action name="alert" url="src/actions/alert/alert.js" />
    <Action name="goto" url="src/actions/goto/goto.js" />
  </Actions>

</Application>
